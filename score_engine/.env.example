# ── Score mode ────────────────────────────────────────────────────────────────
# Controls the data-fetch layer for non-demo wallets.
#   mock    → JSON profiles (no external calls). Requires DEMO_WALLET_* vars.
#   sandbox → Plaid sandbox + Argyle sandbox + Helius devnet (default)
#   live    → Plaid production + Argyle production + Helius mainnet
SCORE_MODE=sandbox

# ── Demo wallet addresses ─────────────────────────────────────────────────────
# Base58 Solana public keys created by scripts/create_demo_wallets.py.
# Wallets listed here are always routed to mock mode regardless of SCORE_MODE.
DEMO_WALLET_MARIA=
DEMO_WALLET_JAMES=
DEMO_WALLET_NO_HISTORY=

# ── Macro data (FRED API) ──────────────────────────────────────────────────────
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
# Falls back to hardcoded April 2026 values if not set.
FRED_API_KEY=

# ── Plaid (bank cashflow) ──────────────────────────────────────────────────────
# Required for sandbox and live modes. Get credentials at https://plaid.com/docs/
# The sandbox secret is different from the production secret.
PLAID_CLIENT_ID=
PLAID_SECRET_SANDBOX=
PLAID_SECRET_PRODUCTION=

# ── Argyle (gig income) ────────────────────────────────────────────────────────
# Optional — only needed for users with gig income (Uber, DoorDash, etc.).
# Get credentials at https://argyle.com/
ARGYLE_CLIENT_ID=
ARGYLE_CLIENT_SECRET=

# ── Helius (Solana on-chain data) ─────────────────────────────────────────────
# Optional — returns zeros if not set (useful for local dev without Solana node).
# Free API key: https://dev.helius.xyz
# Use the same key for devnet and mainnet (Helius routes by network in the URL).
HELIUS_API_KEY=

# ── USDC mint address ─────────────────────────────────────────────────────────
# Default: devnet USDC (4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU)
# For live mode, set to mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:3000 and http://localhost:3001 if not set.
# CORS_ORIGINS=http://localhost:3000,https://avere.app
